mixin createMenu(menu, active)
    each value, key in menu
        if active == key
            a.active(href= value)= key
        else
            a(href= value)= key

mixin sectionList(listSections)
  each item in listSections
    section
      h3= item.header
      img(src= require("../images/" + item.image))
      p= item.text
        a(href="#") &hellip;

mixin imagesList(listImages)
  each pict in listImages
    a(href="building.html")
        img(src= require("../images/" + pict))

mixin createMenuBuild(menu, activeText)
  a(href=menu["Главная"]) Главная
  a.active(href="#")= activeText
  each value, key in menu
    if key !== "Главная"
      a(href=value)= key