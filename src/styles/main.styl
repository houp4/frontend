img.big
    display block
    margin 0 auto
    width 30%

section
    display grid
    grid-template-columns 1fr 1fr
    grid-gap 20px
    margin-top 20px

@media (max-width: 768px)
  
  div.images
    grid-template-columns: 1fr
    grid-gap: 15px
  
  article
    grid-template-columns: 1fr
    width: 100%
    grid-gap: 25px
    


  